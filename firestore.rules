rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══ Helper Functions ══
    function isAuth() {
      return request.auth != null;
    }
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function role() {
      return userExists() ? getUserDoc().data.role : '';
    }
    function isAdmin() {
      return role() in ['admin', 'operation_manager'];
    }
    function perms() {
      return userExists() ? getUserDoc().data.get('permissions', {}) : {};
    }
    function pages() {
      return perms().get('pages', []);
    }
    function hasPage(page) {
      return isAdmin() || pages().hasAny([page, '*']);
    }
    function can(perm) {
      return isAdmin() || perms().get(perm, false) == true;
    }
    function validTx() {
      let d = request.resource.data;
      return d.amount is number && d.amount > 0
          && d.type in ['in', 'out']
          && d.walletId is string && d.walletId.size() > 0;
    }

    // ══ Users ══
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ══ Employees ══
    match /employees/{empId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ══ Employee Payments ══
    match /employee_payments/{payId} {
      allow read: if isAuth() && isAdmin();
      allow create: if isAuth() && isAdmin();
      allow update, delete: if isAdmin();
    }

    // ══ Orders ══
    match /orders/{orderId} {
      allow read: if isAuth() && (
        isAdmin() ||
        can('canSeeAllOrders') ||
        hasPage('shipping') ||
        hasPage('production') ||
        hasPage('design') ||
        hasPage('print') ||
        hasPage('clients') ||
        resource.data.get('createdBy','__') == request.auth.uid ||
        resource.data.get('designerId','__') == request.auth.uid ||
        resource.data.get('productionAgent','__') == request.auth.uid ||
        resource.data.get('shippingOfficer','__') == request.auth.uid
      );
      allow create: if isAuth() && (isAdmin() || can('canAddOrders'));
      allow update: if isAuth() && (
        isAdmin() ||
        can('canAddOrders') ||
        hasPage('shipping') ||
        hasPage('production') ||
        hasPage('design') ||
        hasPage('print') ||
        resource.data.get('createdBy','__') == request.auth.uid ||
        resource.data.get('designerId','__') == request.auth.uid ||
        resource.data.get('productionAgent','__') == request.auth.uid ||
        resource.data.get('shippingOfficer','__') == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ══ Clients ══
    match /clients/{clientId} {
      allow read: if isAuth() && (
        isAdmin() ||
        hasPage('clients') ||
        resource.data.get('createdBy','__') == request.auth.uid
      );
      allow create: if isAuth() && (isAdmin() || can('canAddClients'));
      allow update: if isAuth() && (
        isAdmin() ||
        can('canAddClients') ||
        resource.data.get('createdBy','__') == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ══ Wallets ══
    match /wallets/{walletId} {
      allow read: if isAuth() && (
        isAdmin() ||
        hasPage('accounts') ||
        hasPage('shipping-accounts') ||
        hasPage('shipping') ||
        hasPage('clients') ||
        hasPage('print') ||
        can('canAddOrders')
      );
      allow create: if isAdmin();
      allow update: if isAuth() && (
        isAdmin() ||
        hasPage('accounts') ||
        hasPage('shipping-accounts') ||
        hasPage('shipping') ||
        hasPage('suppliers') ||
        can('canAddOrders')
      );
      allow delete: if isAdmin();
    }

    // ══ Transactions ══
    match /transactions_v2/{txId} {
      allow read: if isAuth() && (
        isAdmin() ||
        hasPage('accounts') ||
        hasPage('shipping') ||
        hasPage('shipping-accounts') ||
        can('canAddOrders')
      );
      allow create: if isAuth()
        && (isAdmin() || hasPage('accounts') || hasPage('shipping') || hasPage('shipping-accounts') || can('canAddOrders'))
        && validTx();
      allow update, delete: if isAdmin();
    }

    // ══ Products ══
    match /products_v2/{prodId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ══ Suppliers ══
    match /suppliers_v2/{supId} {
      allow read: if isAuth() && (isAdmin() || hasPage('suppliers'));
      allow write: if isAdmin();
    }
    match /supplier_payments/{payId} {
      allow read: if isAuth() && (isAdmin() || hasPage('suppliers') || hasPage('accounts'));
      allow create: if isAuth() && (isAdmin() || hasPage('suppliers') || hasPage('accounts'));
      allow update, delete: if isAdmin();
    }

    // ══ Shippers ══
    match /shippers_v2/{shipId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ══ Designers (legacy) ══
    match /designers_v2/{desId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ══ Attendance ══
    match /attendance/{attId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get('employeeUid','__') == request.auth.uid
      );
      allow create: if isAuth() && (
        isAdmin() ||
        request.resource.data.get('employeeUid','') == request.auth.uid
      );
      allow update: if isAuth() && (
        isAdmin() ||
        resource.data.get('employeeUid','__') == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ══ Tasks ══
    match /tasks/{taskId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get('assignedTo','__') == request.auth.uid ||
        resource.data.get('assignedBy','__') == request.auth.uid
      );
      allow create: if isAuth() && (isAdmin() || can('canAssignTasks'));
      allow update: if isAuth() && (
        isAdmin() ||
        resource.data.get('assignedTo','__') == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ══ Shipping ══
    match /shipping_settlements/{settId} {
      allow read: if isAuth() && (
        isAdmin() || hasPage('shipping') || hasPage('shipping-accounts')
      );
      allow write: if isAuth() && (
        isAdmin() || hasPage('shipping-accounts')
      );
    }
    match /shipping_returns/{retId} {
      allow read: if isAuth() && (
        isAdmin() || hasPage('shipping') || hasPage('shipping-accounts')
      );
      allow create: if isAuth() && (
        isAdmin() || hasPage('shipping') || hasPage('shipping-accounts')
      );
      allow update, delete: if isAdmin();
    }

    // ══ Reconciliations ══
    match /reconciliations/{recId} {
      allow read: if isAuth() && (isAdmin() || hasPage('accounts'));
      allow create: if isAuth() && (isAdmin() || hasPage('accounts'));
      allow update, delete: if isAdmin();
    }

    // ══ Settings ══
    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ══ Financial Ledger ══
    // create: أي مستخدم مصادق عليه (يُسجَّل من كل صفحة تلقائياً)
    // update/delete: أدمن فقط (تعديل وحذف منطقي مع سجل تدقيق)
    // read: أدمن + أصحاب الصفحات المالية
    match /financial_ledger/{entryId} {
      allow read: if isAuth() && (
        isAdmin() ||
        hasPage('accounts') ||
        hasPage('shipping') ||
        hasPage('suppliers') ||
        hasPage('production') ||
        hasPage('print')
      );
      allow create: if isAuth() && request.auth.uid != null;
      allow update: if isAuth() && isAdmin();
      allow delete: if isAuth() && isAdmin();
    }

    // ══ Print Jobs ══
    match /print_jobs/{jobId} {
      allow read: if isAuth() && (
        isAdmin() || hasPage('print') || hasPage('production')
      );
      allow create: if isAuth() && (isAdmin() || hasPage('print'));
      allow update: if isAuth() && (
        isAdmin() || hasPage('print') || hasPage('production')
      );
      allow delete: if isAdmin();
    }
  }
}
