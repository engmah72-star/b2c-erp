rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══ Helper Functions ══
    function isAuth() {
      return request.auth != null;
    }
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function role() {
      return userExists() ? getUserDoc().data.role : '';
    }
    function isAdmin() {
      // وصول واسع — admin + operation_manager (للتشغيل اليومي: orders/clients/...).
      // لا تستخدم لإعادة لمس الكيانات الحساسة — استخدم isAdminOnly().
      return role() in ['admin', 'operation_manager'];
    }
    function isAdminOnly() {
      // الإدارة الفعلية فقط — حذف users/orders/clients، إنشاء/حذف wallets/products،
      // settings، الموافقة النهائية في approval workflow.
      // ops_manager محجوب عن هذه القواعد.
      return role() == 'admin';
    }
    function perms() {
      return userExists() ? getUserDoc().data.get('permissions', {}) : {};
    }
    function pages() {
      return perms().get('pages', []);
    }
    function hasPage(page) {
      return isAdmin() || pages().hasAny([page, '*']);
    }
    function can(perm) {
      return isAdmin() || perms().get(perm, false) == true;
    }
    function validTx() {
      let d = request.resource.data;
      return d.amount is number && d.amount > 0
          && d.type in ['in', 'out']
          && d.category is string
          && (d.walletId == null || d.walletId is string);
    }
    // ══ Financial collection access — مصدر واحد للأذونات المالية ══
    // إضافة صفحة جديدة تكتب في wallets/transactions_v2/financial_ledger:
    //   1) أضفها هنا في canFinancialWrite()
    //   2) أو امنح المستخدم perms.canFinancialWrite=true
    function canFinancialWrite() {
      return isAdmin()
          || hasPage('accounts')
          || hasPage('shipping')
          || hasPage('shipping-accounts')
          || hasPage('suppliers')
          || hasPage('production')
          || hasPage('design')
          || hasPage('print')
          || hasPage('clients')
          || can('canAddOrders')
          || can('canFinancialWrite');
    }
    function canFinancialRead() {
      return isAdmin()
          || hasPage('accounts')
          || hasPage('shipping')
          || hasPage('shipping-accounts')
          || hasPage('suppliers')
          || hasPage('production')
          || hasPage('design')
          || hasPage('print')
          || hasPage('clients')
          || can('canAddOrders')
          || can('canFinancialWrite')
          || can('canFinancialRead');
    }
    function validLedger() {
      let d = request.resource.data;
      // كل قيد يجب أن يربط بكيان واحد على الأقل (RULE 5: full audit)
      let hasEntity = (d.get('orderId', null)    != null && d.orderId    != '')
                   || (d.get('clientId', null)   != null && d.clientId   != '')
                   || (d.get('employeeId', null) != null && d.employeeId != '')
                   || (d.get('vendorId', null)   != null && d.vendorId   != '')
                   || (d.get('walletId', null)   != null && d.walletId   != '')
                   || (d.get('refId', null)      != null && d.refId      != '');
      return d.amount is number && d.amount > 0
          && d.eventType is string
          && d.type in ['income', 'expense', 'reversal', 'transfer', 'other']
          && d.direction in ['in', 'out']
          && hasEntity
          && d.get('isDeleted', false) == false;
    }
    // ══ Approval workflow helpers ══
    // الـ tx/ledger الجديدة تبدأ approvalStatus='pending'
    // ops_manager يقدر pending → confirmed أو pending → rejected
    // admin يقدر confirmed → approved (نهائي + isLocked=true)، أو أي → rejected
    function isOpsManager() {
      return role() == 'operation_manager';
    }
    function isApprovalUpdate() {
      // تحديث يقتصر على حقول الاعتماد فقط — لا يلمس amount/walletId/category/...
      let allowed = ['approvalStatus','confirmedBy','confirmedByName','confirmedAt',
                     'approvedBy','approvedByName','approvedAt',
                     'rejectedBy','rejectedByName','rejectedAt','rejectReason',
                     'isLocked'];
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return changedKeys.hasOnly(allowed);
    }
    function canConfirm() {
      // ops_manager أو admin يقدر يأكد
      return (isAdmin() || isOpsManager())
          && resource.data.get('approvalStatus','pending') == 'pending'
          && request.resource.data.approvalStatus in ['confirmed','rejected'];
    }
    function canApprove() {
      // admin فقط يعتمد (والاعتماد يتطلب confirmed سابقاً)
      // إلا لو admin اختار "اعتماد مباشر" — مسموح من pending مباشرة
      return isAdminOnly()
          && resource.data.get('approvalStatus','pending') in ['pending','confirmed']
          && request.resource.data.approvalStatus in ['approved','rejected']
          && request.resource.data.get('isLocked', false) == true;
    }
    function isLocked() {
      return resource.data.get('isLocked', false) == true;
    }

    // ══ Users ══
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAdminOnly();
      allow update: if isAuth() && (request.auth.uid == userId || isAdminOnly());
      allow delete: if isAdminOnly();
    }

    // ══ Employees ══
    match /employees/{empId} {
      allow read: if isAuth();
      allow write: if isAdminOnly();
    }

    // ══ Employee Payments ══
    // Admins write; employees may read their own (resolved via the
    // employees doc's authUid → matches the requesting user).
    match /employee_payments/{payId} {
      allow read: if isAuth() && (
        isAdmin() ||
        get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid
      );
      allow create: if isAuth() && isAdminOnly();
      allow update, delete: if isAdminOnly();
    }

    // ══ Employee Leaves ══
    match /employee_leaves/{leaveId} {
      allow read: if isAuth() && isAdmin();
      allow create: if isAuth() && isAdmin();
      allow update, delete: if isAdmin();
    }

    // ══ Employee Goals (monthly targets set by admin/ops) ══
    match /employee_goals/{goalId} {
      // employeeId is the employees-doc id, not auth.uid. Resolve via employees doc.
      allow read: if isAuth() && (
        isAdmin() ||
        get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid
      );
      allow create, update: if isAuth() && isAdmin();
      allow delete: if isAdmin();
    }

    // ══ Employee Evaluations (monthly saved snapshots) ══
    match /employee_evaluations/{evalId} {
      allow read: if isAuth() && (
        isAdmin() ||
        get(/databases/$(database)/documents/employees/$(resource.data.employeeId)).data.authUid == request.auth.uid
      );
      allow create, update: if isAuth() && isAdmin();
      allow delete: if isAdmin();
    }

    // ══ Employee Incidents (HR — quality/attendance/complaint failures) ══
    // Admin-only writes; employees can read their own.
    match /employee_incidents/{incId} {
      allow read: if isAuth() && (isAdmin() || resource.data.authUid == request.auth.uid);
      allow create, update: if isAuth() && isAdmin();
      allow delete: if isAdmin();
    }

    // ══ Orders ══
    // Stage Gate (يوافق orders.js):
    //   design → printing → production → shipping → archived
    // Admin/operation_manager يمكنهم القفز بين المراحل (override).
    // أدوار التشغيل يمكنها فقط الانتقال المسموح من مرحلتها الحالية.
    function canAdvanceFromStage(prev, next) {
      // الانتقال للأمام بالترتيب
      let validForward = (prev == 'design'    && next == 'printing'   && (hasPage('design') || hasPage('clients')))
                      || (prev == 'printing'  && next == 'production' && (hasPage('print')  || hasPage('clients')))
                      || (prev == 'production'&& next == 'shipping'   && hasPage('production'))
                      || (prev == 'production'&& next == 'archived'   && hasPage('production'))
                      || (prev == 'shipping'  && next == 'archived'   && hasPage('shipping'));
      // الارتداد للخلف (مرفوض من المرحلة التالية)
      let validRevert  = (prev == 'printing'  && next == 'design'     && (hasPage('print')      || hasPage('design')))
                      || (prev == 'production'&& next == 'printing'   && (hasPage('production') || hasPage('print')))
                      || (prev == 'shipping'  && next == 'production' && (hasPage('shipping')   || hasPage('production')));
      // الإلغاء متاح من أي مرحلة قبل الأرشفة لمن له clients/admin
      let validCancel  = next == 'cancelled' && (hasPage('clients') || hasPage('shipping'));
      return validForward || validRevert || validCancel;
    }
    function isValidStageUpdate() {
      let prev = resource.data.get('stage', '');
      let next = request.resource.data.get('stage', '');
      // لا يتغير stage → السماح (تحديث حقول أخرى)
      // الأرشفة (next='archived') ممنوعة لو الأوردر له remaining > 0:
      //   - مكتمل الدفع: remaining<=0 أو paymentStatus='paid' → مسموح
      //   - أو الأوردر مرتجع/ملغي: paymentStatus in ['returned','refunded'] → مسموح
      let archivePayOk = next != 'archived'
                       || request.resource.data.get('remaining', 0) <= 0
                       || request.resource.data.get('paymentStatus', '') in ['paid','returned','refunded'];
      return prev == next || (archivePayOk && (isAdmin() || canAdvanceFromStage(prev, next)));
    }

    match /orders/{orderId} {
      allow read: if isAuth() && (
        isAdmin() ||
        can('canSeeAllOrders') ||
        hasPage('shipping') ||
        hasPage('production') ||
        hasPage('design') ||
        hasPage('print') ||
        hasPage('clients') ||
        resource.data.get('createdBy','__') == request.auth.uid ||
        resource.data.get('designerId','__') == request.auth.uid ||
        resource.data.get('productionAgent','__') == request.auth.uid ||
        resource.data.get('shippingOfficerId','__') == request.auth.uid
      );
      allow create: if isAuth() && (isAdmin() || can('canAddOrders'));
      allow update: if isAuth() && (
        isAdmin() ||
        can('canAddOrders') ||
        hasPage('shipping') ||
        hasPage('production') ||
        hasPage('design') ||
        hasPage('print') ||
        resource.data.get('createdBy','__') == request.auth.uid ||
        resource.data.get('designerId','__') == request.auth.uid ||
        resource.data.get('productionAgent','__') == request.auth.uid ||
        resource.data.get('shippingOfficerId','__') == request.auth.uid
      ) && isValidStageUpdate();
      allow delete: if isAdminOnly();
    }

    // ══ Clients ══
    match /clients/{clientId} {
      allow read: if isAuth() && (
        isAdmin() ||
        hasPage('clients') ||
        can('canViewClients') ||
        can('canAddClients') ||
        can('canFollowUpClients') ||
        can('canArchiveClients') ||
        resource.data.get('createdBy','__') == request.auth.uid
      );
      allow create: if isAuth() && (isAdmin() || can('canAddClients'));
      // Update covers add-style edits + follow-up notes + archive flag.
      // Each is a separate permission so a CS rep can be allowed to follow up
      // without being able to add new clients, etc.
      allow update: if isAuth() && (
        isAdmin() ||
        can('canAddClients') ||
        can('canFollowUpClients') ||
        can('canArchiveClients') ||
        hasPage('print') ||
        resource.data.get('createdBy','__') == request.auth.uid
      );
      allow delete: if isAdminOnly();
    }

    // ══ Wallets ══
    match /wallets/{walletId} {
      allow read:   if isAuth() && canFinancialRead();
      allow create: if isAdminOnly();
      allow update: if isAuth() && canFinancialWrite();
      allow delete: if isAdminOnly();
    }

    // ══ Transactions ══
    match /transactions_v2/{txId} {
      allow read:   if isAuth() && canFinancialRead();
      allow create: if isAuth() && canFinancialWrite() && validTx();
      // التحديث: admin يقدر يعمل أي تعديل (لكن المغلق محمي حتى من admin إلا للاعتماد)
      // ops_manager يقدر يأكد فقط (تحديث حقول approval)
      // أي مستخدم آخر: ممنوع
      allow update: if isAuth() && (
        // قفل: لا تعديل بعد الاعتماد إلا لو admin يحدّث حقول approval فقط
        (isLocked() ? (isAdmin() && isApprovalUpdate())
                    : (isAdmin() || (isOpsManager() && isApprovalUpdate() && canConfirm())
                                 || (isAdmin() && isApprovalUpdate())))
      );
      allow delete: if isAdminOnly() && !isLocked();
    }

    // ══ Products ══
    // قراءة: أي auth user (للأوردرات، التسعير، إلخ)
    // إنشاء/حذف: admin فقط
    // تحديث: admin أو من معه permission المنتجات يقدر يحدّث أي شيء.
    //        من معه permission الإنتاج فقط (بدون products perm) يقدر يضيف
    //        تكاليف بس (costHistory + lastCostTotal + updatedAt) — مش يقدر
    //        يغيّر اسم المنتج أو السعر الافتراضي.
    match /products_v2/{prodId} {
      allow read: if isAuth();
      allow create, delete: if isAdminOnly();
      allow update: if isAuth() && (
        isAdmin() || hasPage('products') ||
        (hasPage('production')
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['costHistory','lastCostTotal','updatedAt']))
      );
    }

    // ══ Suppliers ══
    match /suppliers_v2/{supId} {
      allow read: if isAuth() && (isAdmin() || hasPage('suppliers'));
      // Admin + holders of `canAddSuppliers` can create/update; deletion stays admin-only.
      allow create, update: if isAuth() && (isAdmin() || can('canAddSuppliers'));
      allow delete: if isAdminOnly();
    }
    match /supplier_payments/{payId} {
      allow read: if isAuth() && (isAdmin() || hasPage('suppliers') || hasPage('accounts'));
      allow create: if isAuth() && (isAdmin() || hasPage('suppliers') || hasPage('accounts'));
      allow update, delete: if isAdminOnly();
    }

    // ══ Shippers ══
    match /shippers_v2/{shipId} {
      allow read: if isAuth() && (isAdmin() || hasPage('shipping') || hasPage('suppliers') || hasPage('shipping-accounts'));
      // shippers_v2 يستخدم نفس صلاحية canAddSuppliers (suppliers.html تدير الاثنين).
      allow create, update: if isAuth() && (isAdmin() || can('canAddSuppliers'));
      allow delete: if isAdminOnly();
    }

    // ══ Designers (legacy) ══
    match /designers_v2/{desId} {
      allow read: if isAuth() && (isAdmin() || hasPage('design'));
      allow write: if isAdmin();
    }

    // ══ Attendance ══
    match /attendance/{attId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get('employeeUid','__') == request.auth.uid
      );
      allow create: if isAuth() && (
        isAdmin() ||
        request.resource.data.get('employeeUid','') == request.auth.uid
      );
      allow update: if isAuth() && (
        isAdmin() ||
        resource.data.get('employeeUid','__') == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ══ Tasks ══
    match /tasks/{taskId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get('assignedTo','__') == request.auth.uid ||
        resource.data.get('assignedBy','__') == request.auth.uid
      );
      allow create: if isAuth() && (isAdmin() || can('canAssignTasks'));
      allow update: if isAuth() && (
        isAdmin() ||
        resource.data.get('assignedTo','__') == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ══ Notifications ══
    // إشعارات النظام (مثلاً: حذف بند تكلفة مدفوع)
    // المستلِم يقرأ إشعاراته فقط، الكتابة مفتوحة لكل المصادقين
    match /notifications/{notId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get('toUid','__') == request.auth.uid
      );
      allow create: if isAuth();
      allow update: if isAuth() && (
        isAdmin() ||
        resource.data.get('toUid','__') == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ══ Shipping ══
    match /shipping_settlements/{settId} {
      allow read: if isAuth() && (
        isAdmin() || hasPage('shipping') || hasPage('shipping-accounts') || hasPage('accounts')
      );
      allow write: if isAuth() && (
        isAdmin() || hasPage('shipping-accounts')
      );
    }
    match /shipping_returns/{retId} {
      allow read: if isAuth() && (
        isAdmin() || hasPage('shipping') || hasPage('shipping-accounts') || hasPage('accounts')
      );
      allow create: if isAuth() && (
        isAdmin() || hasPage('shipping') || hasPage('shipping-accounts') || can('canAddOrders')
      );
      allow update, delete: if isAdmin();
    }

    // ══ Reconciliations ══
    match /reconciliations/{recId} {
      allow read: if isAuth() && (isAdmin() || hasPage('accounts'));
      allow create: if isAuth() && (isAdmin() || hasPage('accounts'));
      allow update, delete: if isAdminOnly();
    }

    // ══ Settings ══
    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if isAdminOnly();
    }

    // ══ Financial Ledger ══
    match /financial_ledger/{entryId} {
      allow read:   if isAuth() && canFinancialRead();
      allow create: if isAuth() && canFinancialWrite() && validLedger();
      // المغلق محمي: حتى admin لا يقدر يعدّل بعد الاعتماد إلا حقول الاعتماد فقط
      // ops_manager يقدر يأكد فقط (تحديث حقول الاعتماد)
      allow update: if isAuth() && (
        (isLocked() ? (isAdmin() && isApprovalUpdate())
                    : (isAdmin() || (isOpsManager() && isApprovalUpdate() && canConfirm())))
      );
      allow delete: if isAuth() && isAdminOnly() && !isLocked();
    }

    // ══ Payment Requests ══
    // أي موظف يقدر ينشئ طلب (دفعة مورد / مرتب / سلفة)
    // المحاسب ينفّذ → الطالب يستلم بإيصال → ops يؤكد → admin يعتمد
    match /payment_requests/{reqId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'requested'
        && request.resource.data.amount is number
        && request.resource.data.amount > 0;
      allow update: if isAuth() && (
        // المحاسب/مدير التشغيل ينفّذ: requested → awaiting_receipt أو مباشرة → pending (لو رفع الإيصال في نفس الخطوة)
        (canFinancialWrite()
         && resource.data.status == 'requested'
         && request.resource.data.status in ['awaiting_receipt','pending','rejected'])
        // الطالب يلغي طلبه الخاص: requested → rejected (لم يبدأ التنفيذ بعد)
        || (resource.data.requestedBy == request.auth.uid
            && resource.data.status == 'requested'
            && request.resource.data.status == 'rejected')
        // رفع إيصال awaiting_receipt → pending: مدير التشغيل/الأدمن أو الطالب (backward compat)
        || ((isOpsManager() || isAdmin() || canFinancialWrite() || resource.data.requestedBy == request.auth.uid)
            && resource.data.status == 'awaiting_receipt'
            && request.resource.data.status == 'pending'
            && request.resource.data.receiptImageUrl is string)
        // ops_manager يأكد (backward compat للسجلات القديمة): pending → confirmed
        || (isOpsManager()
            && resource.data.status == 'pending'
            && request.resource.data.status in ['confirmed','rejected'])
        // admin يعتمد: pending/confirmed → approved (locked) — يعتمد مباشرة بدون مرحلة confirmed منفصلة
        || (isAdmin()
            && resource.data.status in ['pending','confirmed']
            && request.resource.data.status in ['approved','rejected'])
      );
      allow delete: if isAdminOnly();
    }

    // ══ Chat (legacy chat_messages — kept for read access to history) ══
    match /chat_messages/{msgId} {
      allow read: if isAuth() && (isAdmin() || can('canUseChat') || hasPage('chat'));
      allow create: if isAuth() && (isAdmin() || can('canUseChat') || hasPage('chat'));
      allow update, delete: if isAdmin();
    }

    // ══ Inbox v2 — conversations + messages + presence ══
    // كل user يقرأ المحادثات اللي هو participant فيها فقط.
    // الـ messages داخل subcollection محمية بنفس المنطق.
    match /conversations/{convId} {
      allow read: if isAuth() && (
        isAdmin() ||
        request.auth.uid in resource.data.get('participants', [])
      );
      // create: any auth user can create a DM, but must include themselves
      allow create: if isAuth() && request.auth.uid in request.resource.data.get('participants', []);
      // update:
      //   1) Participant: standard update — toggle unread, archive, last…
      //   2) NON-participant joining a CHANNEL: allowed to add only themselves
      //      to participants (so new employees / role changes can self-join).
      allow update: if isAuth() && (
        request.auth.uid in resource.data.get('participants', [])
        || (
          resource.data.get('type','') == 'channel'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants'])
          && request.auth.uid in request.resource.data.get('participants', [])
          && !(request.auth.uid in resource.data.get('participants', []))
        )
      );
      allow delete: if isAdminOnly();

      match /messages/{msgId} {
        allow read: if isAuth() && (
          isAdmin() ||
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.get('participants', [])
        );
        // create: must be participant and senderId must match auth uid
        allow create: if isAuth()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.get('participants', []);
        // update: only readBy + reactions + editedAt updates by participants
        allow update: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.get('participants', []);
        allow delete: if isAdmin() || (isAuth() && resource.data.senderId == request.auth.uid);
      }
    }

    // Presence — every auth user can read/write only their own doc.
    match /presence/{uid} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid;
    }

    // ══ اللحظات (Stories) — 24h disappearing ══
    // كل auth user يقرأ كل اللحظات (zي ما الـ presence collection)
    // الإنشاء: لازم userId يطابق uid
    // التحديث: المالك ولا أي مشاهد بيضيف نفسه في viewers فقط
    // الحذف: المالك فقط أو admin
    match /stories/{storyId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (
        // المالك يقدر يحدث أي حاجة
        resource.data.userId == request.auth.uid
        // أي مشاهد يضيف نفسه فقط في viewers (لا يلمس باقي الحقول)
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewers'])
            && request.auth.uid in request.resource.data.viewers)
      );
      allow delete: if isAuth() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // ══ Print Jobs ══
    match /print_jobs/{jobId} {
      allow read: if isAuth() && (
        isAdmin() || hasPage('print') || hasPage('production')
      );
      allow create: if isAuth() && (isAdmin() || hasPage('print'));
      allow update: if isAuth() && (
        isAdmin() || hasPage('print') || hasPage('production')
      );
      allow delete: if isAdmin();
    }

    // ══ Design Gallery — internal designer workspace (auth required) ══
    // ملاحظة: الجاليري العام للزوار = /gallery (مختلف).
    match /design_gallery/{itemId} {
      allow read: if isAuth() && (isAdmin() || hasPage('design'));
      allow create: if isAuth() && (isAdmin() || hasPage('design'));
      allow update, delete: if isAuth() && (isAdmin() || request.auth.uid == resource.data.designerId);
    }

    // ══ Gallery — public read, designers & admins write ══
    // ملاحظة تجارية: القراءة عامة عن قصد — gallery.html يعرض التصاميم للزوار كدعاية.
    match /gallery/{itemId} {
      allow read: if true;
      allow create: if isAuth() && (isAdmin() || hasPage('design'));
      allow update: if isAuth() && (isAdmin() || hasPage('design'));
      allow delete: if isAdmin();
    }

    // ══ Design Items — designer workspace tracking ══
    // ملاحظة تجارية: القراءة عامة عن قصد — ملفات الموك أب تخدم كدعاية للشركة.
    // الكتابة محصورة على المصممين/الأدمن فقط.
    match /design_items/{itemId} {
      allow read: if true;
      allow create: if isAuth() && (isAdmin() || hasPage('design'));
      allow update: if isAuth() && (isAdmin() || hasPage('design'));
      allow delete: if isAdmin();
    }

    // ══ Client Follow-ups — متابعات العملاء (CRM, non-financial) ══
    // كل من له وصول إلى clients يقدر يضيف/يقرأ متابعات. الحذف soft فقط (isDeleted).
    match /client_followups/{fId} {
      allow read: if isAuth() && (
        isAdmin() || hasPage('clients') ||
        resource.data.get('createdBy','__') == request.auth.uid ||
        resource.data.get('assignedTo','__') == request.auth.uid
      );
      allow create: if isAuth() && (
        isAdmin() || hasPage('clients') || can('canAddClients')
      ) && request.resource.data.keys().hasAll(['clientId','type','createdBy','createdAt'])
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuth() && (
        isAdmin() || hasPage('clients') ||
        resource.data.get('createdBy','__') == request.auth.uid ||
        resource.data.get('assignedTo','__') == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ══ WhatsApp Logs — مكتوبة فقط من Cloud Functions (admin SDK يتجاوز الـ rules) ══
    // الأدمن يقرأ السجلات للمراجعة. ممنوع الكتابة من العميل.
    match /whatsapp_logs/{logId} {
      allow read: if isAuth() && isAdminOnly();
      allow write: if false;
    }

    // ══ Supplier Orders — طلبات توريد رسمية (document per external cost item) ══
    match /supplier_orders/{soId} {
      allow read: if isAuth() && (isAdmin() || hasPage('production') || hasPage('suppliers') || hasPage('accounts'));
      allow create: if isAuth() && (isAdmin() || hasPage('production'));
      allow update: if isAuth() && (isAdmin() || hasPage('production') || hasPage('suppliers'));
      allow delete: if isAdmin();
    }

    // ══ Client Decisions — client portal creates (token-based, no Firebase auth) ══
    // العملاء يستخدمون بوابة بدون Firebase auth.
    // الحماية: لا يقدر مهاجم ينشئ قرار لطلب ليس له — لازم يعرف clientPhone للطلب.
    match /client_decisions/{decId} {
      allow read: if isAuth();
      allow create:
        // ١) الحقول المطلوبة
        if request.resource.data.keys().hasAll(['orderDocId','itemId','decision','clientPhone'])
        && request.resource.data.orderDocId is string
        && request.resource.data.itemId is string
        && request.resource.data.clientPhone is string
        && request.resource.data.decision in ['approved','revision']
        && request.resource.data.get('processed', false) == false
        // ٢) Ownership: clientPhone في القرار = clientPhone في الطلب (cross-validate)
        && request.resource.data.clientPhone ==
           get(/databases/$(database)/documents/orders/$(request.resource.data.orderDocId)).data.clientPhone;
      allow update, delete: if isAdmin() || (isAuth() && hasPage('design'));
    }

    // ══ Master Lists — قوائم مركزية (تصنيفات، خدمات) ══
    // كل المصادقين يقرأون، الأدمن فقط يكتب
    match /master_lists/{listId} {
      allow read: if isAuth();
      allow write: if isAdminOnly();
    }

    // ══ Print Brief Templates — قوالب الإنتاج (عمليات يومية) ══
    // CS/print/admin يحفظون قوالب — أعم من admin-only في master_lists
    match /master_lists/print_brief_templates {
      allow write: if isAuth() && (
        isAdmin() || hasPage('print') || hasPage('clients') || hasPage('design')
      );
    }

    // ══ Audit Logs — سجل الـ admin overrides والعمليات الحساسة ══
    // immutable: لا تعديل ولا حذف بعد الكتابة
    // قراءة: admin فقط (للتدقيق)
    // إنشاء: أي مستخدم بصلاحية كتابة مالية أو إدارية
    match /audit_logs/{logId} {
      allow read: if isAuth() && isAdminOnly();
      allow create: if isAuth() && request.resource.data.keys().hasAll(['action','userId','timestamp']);
      allow update, delete: if false;
    }

    // ══ FCM Tokens ══
    // المستخدم يقدر يكتب/يحذف tokens الخاصة بـ uid بتاعه فقط.
    // الكتابة الفعلية تتم عبر callable functions (registerFcmToken / unregisterFcmToken)
    // عشان الـ Functions تتأكد من شكل الـ token قبل التسجيل، لكن نسمح بالكتابة المباشرة
    // كـ fallback للعميل لو الـ callable فشل (مثلاً offline).
    match /fcm_tokens/{tokenId} {
      allow read:   if isAuth() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid
                                && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && (isAdmin() || resource.data.uid == request.auth.uid);
    }

    // ══ Admin Alerts — تنبيهات الحركات المالية الحرجة ══
    // الكتابة من Cloud Functions فقط (Admin SDK يتجاوز الـ rules).
    // الأدمن/operation_manager يقرأ + يقدر يضع acknowledged=true فقط.
    match /admin_alerts/{alertId} {
      allow read: if isAuth() && isAdmin();
      allow create: if false;
      allow update: if isAuth() && isAdmin()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['acknowledged','acknowledgedBy','acknowledgedByName','acknowledgedAt']);
      allow delete: if isAdminOnly();
    }

    // ══ Archived Orders — أوردرات نُقلت تلقائيًا (>6 شهور + مدفوعة) ══
    // الكتابة من Cloud Functions فقط. القراءة: نفس صلاحيات orders.
    match /archived_orders/{orderId} {
      allow read: if isAuth() && (
        isAdmin() ||
        can('canSeeAllOrders') ||
        hasPage('archive') ||
        hasPage('clients') ||
        resource.data.get('createdBy','__') == request.auth.uid ||
        resource.data.get('clientId','__')  == request.auth.uid
      );
      allow create, update: if false;
      allow delete: if isAdminOnly();
    }

    // ══ Backup Logs — سجل التشغيل لمهمة النسخ الاحتياطي اليومية ══
    // الكتابة من Cloud Functions فقط. القراءة: admin للمراجعة.
    match /backup_logs/{logId} {
      allow read: if isAuth() && isAdminOnly();
      allow write: if false;
    }

    // ══ Client Segments — تقسيم RFM وخطر الفقد (يُحسب أسبوعيًا) ══
    // الكتابة من Cloud Functions فقط. القراءة: من له وصول إلى clients.
    match /client_segments/{clientId} {
      allow read: if isAuth() && (
        isAdmin() ||
        hasPage('clients') ||
        can('canViewClients') ||
        can('canFollowUpClients') ||
        can('canAddClients')
      );
      allow write: if false;
    }

    // ══ RFM Runs — لقطة لكل تشغيل أسبوعي للتجزيء (للتاريخ) ══
    match /rfm_runs/{runId} {
      allow read: if isAuth() && (isAdmin() || hasPage('clients'));
      allow write: if false;
    }

    // ══ Forecasts — توقعات الإيراد اليومية (تشغيل أسبوعي) ══
    // الكتابة من Cloud Functions فقط. القراءة: من له وصول للوحات الإدارية.
    match /forecasts/{runId} {
      allow read: if isAuth() && (
        isAdmin() ||
        hasPage('accounts') ||
        hasPage('reports') ||
        canFinancialRead()
      );
      allow write: if false;
    }

    // ══ Product Recommendations per client — توصيات المنتج التالي ══
    match /product_recommendations/{clientId} {
      allow read: if isAuth() && (
        isAdmin() ||
        hasPage('clients') ||
        can('canViewClients') ||
        can('canFollowUpClients') ||
        can('canAddClients') ||
        can('canAddOrders')
      );
      allow write: if false;
    }

    // ══ Product Affinities — مصفوفة "بعد X غالبًا Y" عالمية ══
    match /product_affinities/{prodId} {
      allow read: if isAuth() && (
        isAdmin() ||
        hasPage('clients') ||
        hasPage('production') ||
        can('canAddOrders')
      );
      allow write: if false;
    }

    // ════════════════════════════════════════════════════════════
    // MARKETPLACE PLATFORM — Phase 1 Foundation
    // ════════════════════════════════════════════════════════════
    // BUSINESS DNA: Own The Network, Not The Assets.
    // كل الكتابات هنا admin-only في Phase 1. مع marketplace-engine.js
    // (PR لاحق) ستتحول لـ engine-only writes عبر batches.
    // RULE 2 + 3: لا كتابة مباشرة من صفحات بعد إطلاق الـ engine.
    //
    // ملاحظة: ربط user → tenant سيُضاف في Phase 2 (حقل tenantId على user doc).
    // حتى ذلك الحين، صلاحيات Phase 1 = admin + canFinancialRead للقراءة،
    // والعميل يقدر يشوف طلباته/نزاعاته الخاصة عبر customerId == auth.uid.

    // ══ Tenants — سجل المرشنتس وشركاء المنصة ══
    match /tenants/{tenantId} {
      // كل auth user يقرأ قائمة المرشنتس (لـ catalog ولـ profile lookups).
      allow read: if isAuth();
      // KYC والإدارة admin-only في Phase 1.
      allow create, update, delete: if isAdminOnly();
    }

    // ══ Marketplace Orders — طلبات بين العميل والمرشنت ══
    // مختلفة عن orders الحالية: تحمل tenantId + commission + escrow refs.
    match /marketplace_orders/{orderId} {
      allow read: if isAuth() && (
        isAdmin() ||
        canFinancialRead() ||
        resource.data.get('customerId','__') == request.auth.uid
      );
      // Phase 1: admin يكتب يدوياً. Phase 2: engine فقط.
      allow create, update, delete: if isAdminOnly();
    }

    // ══ Commissions — العمولات المستحقة/المحصلة للمنصة ══
    match /commissions/{commId} {
      allow read: if isAuth() && (isAdmin() || canFinancialRead());
      allow create, update, delete: if isAdminOnly();
    }

    // ══ Escrow Holds — الأموال المحتجزة لحين التسليم ══
    match /escrow_holds/{holdId} {
      allow read: if isAuth() && (
        isAdmin() ||
        canFinancialRead() ||
        resource.data.get('customerId','__') == request.auth.uid
      );
      allow create, update, delete: if isAdminOnly();
    }

    // ══ Payouts — دفعات للمرشنتس/الشحن/الوكلاء ══
    match /payouts/{payoutId} {
      allow read: if isAuth() && (isAdmin() || canFinancialRead());
      allow create, update, delete: if isAdminOnly();
    }

    // ══ Disputes — النزاعات بين الأطراف ══
    match /disputes/{disputeId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get('customerId','__') == request.auth.uid
      );
      // فتح نزاع: أي auth user (سيُضيّق في Phase 2 لأطراف الطلب فقط).
      // إدارة وحل النزاع admin-only في Phase 1.
      allow create: if isAuth();
      allow update, delete: if isAdminOnly();
    }

    // ══ Marketplace Idempotency — يمنع double-processing لنفس الـ event ══
    // يُكتب فقط من marketplace-engine.js في نفس الـ batch مع باقي العمليات.
    match /marketplace_idempotency/{key} {
      allow read:  if isAuth() && isAdmin();
      allow write: if isAuth() && canFinancialWrite();
    }

    // ══ Marketplace Audit Log — للأحداث غير المالية (KYC، dispute open، …) ══
    // financial_ledger مخصص للحركات المالية فقط (RULE 5).
    match /marketplace_audit_log/{entryId} {
      allow read:   if isAuth() && isAdmin();
      allow create: if isAuth() && canFinancialWrite();
      allow update, delete: if false;
    }

    // ══ Marketplace Events Queue — للإشعارات (delivery لاحقاً عبر notifier) ══
    match /marketplace_events/{eventId} {
      allow read:   if isAuth() && isAdmin();
      allow create: if isAuth() && canFinancialWrite();
      // notifier service يحدّث delivered=true بعد الإرسال
      allow update: if isAuth() && isAdmin();
      allow delete: if isAdminOnly();
    }

    // ══ Customer Wallets — رصيد العميل على المنصة (refund destination) ══
    match /customer_wallets/{customerId} {
      allow read: if isAuth() && (isAdmin() || customerId == request.auth.uid);
      // Engine فقط يكتب (RULE 1: مصدر واحد).
      allow write: if isAuth() && canFinancialWrite();
    }
  }
}
