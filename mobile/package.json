{
  "name": "b2c-erp-mobile",
  "version": "1.0.0",
  "description": "Business2Card ERP — iOS & Android native shell (Capacitor) wrapping the production web app.",
  "private": true,
  "scripts": {
    "init:android": "cap add android",
    "init:ios": "cap add ios",
    "sync": "cap sync",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "cap run android",
    "run:ios": "cap run ios",
    "build:android:debug": "cd android && ./gradlew assembleDebug && cd ..",
    "build:android:release": "cd android && ./gradlew assembleRelease && cd ..",
    "icons": "capacitor-assets generate --iconBackgroundColor '#07080f' --iconBackgroundColorDark '#07080f' --splashBackgroundColor '#07080f' --splashBackgroundColorDark '#07080f'"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/browser": "^6.0.3",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/network": "^6.0.3",
    "@capacitor/push-notifications": "^6.0.3",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@capacitor/assets": "^3.0.5"
  }
}
