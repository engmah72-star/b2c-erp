{
  "name": "b2c-rules-tests",
  "version": "1.0.0",
  "description": "Firestore rules regression tests",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node role-escalation.test.js && node financial-write.test.js",
    "test:role": "node role-escalation.test.js",
