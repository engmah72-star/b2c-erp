rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ══════════════════════════════════════════════════════════
    // S0-4: Helper functions باستخدام Auth custom claims
    // ══════════════════════════════════════════════════════════
    // الـ Cloud Function syncUserAuthClaims ينشر:
    //   request.auth.token.role      → دور المستخدم
    //   request.auth.token.tenantId  → الـ tenant
    //   request.auth.token.cfw       → canFinancialWrite flag
    //   request.auth.token.cfr       → canFinancialRead flag
    //
    // backward compat: لو الـ user لم يُعمل له backfillAuthClaims بعد:
    //   request.auth.token.tenantId == null → نعامله كـ 'merchant_001'
    //   request.auth.token.role == null → role check يفشل (آمن، fail-closed)

    function tenantOf(uid) {
      return request.auth != null && request.auth.token.tenantId != null
        ? request.auth.token.tenantId
        : 'merchant_001';
    }
    function userRole() {
      return request.auth != null && request.auth.token.role != null
        ? request.auth.token.role
        : '';
    }
    function isStaff() {
      return userRole() in ['admin','operation_manager','customer_service',
                            'graphic_designer','design_operator','production_agent',
                            'shipping_officer','wallet_manager'];
    }
    function isFinancialRole() {
      return userRole() in ['admin','operation_manager','wallet_manager']
        || request.auth.token.cfw == true
        || request.auth.token.cfr == true;
    }

    // ══════════════════════════════════════════════════════════
    // NEW: Tenant-scoped paths (preferred — استخدمها في الـ uploads الجديدة)
    // ══════════════════════════════════════════════════════════
    // الـ frontend يبني الـ path هكذا:
    //   const path = `receipts/${tenantId}/${user.uid}/${Date.now()}.jpg`;

    // إيصالات طلبات الدفع — tenant + user scoped
    match /receipts/{tenantId}/{userId}/{file=**} {
      allow read: if request.auth != null
        && tenantOf(request.auth.uid) == tenantId
        && (request.auth.uid == userId || isFinancialRole());
      allow write: if request.auth != null
        && tenantOf(request.auth.uid) == tenantId
        && request.auth.uid == userId
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ملفات تصميم — tenant + order scoped
    match /design-files/{tenantId}/{orderId}/{file=**} {
      allow read: if request.auth != null
        && tenantOf(request.auth.uid) == tenantId
        && userRole() in ['admin','operation_manager','customer_service',
                          'graphic_designer','design_operator','production_agent'];
      allow write: if request.auth != null
        && tenantOf(request.auth.uid) == tenantId
        && userRole() in ['admin','operation_manager','customer_service',
                          'graphic_designer','design_operator']
        && request.resource.size < 50 * 1024 * 1024;
    }

    // ملفات الطباعة النهائية — tenant + order scoped
    match /print-finals/{tenantId}/{orderId}/{file=**} {
      allow read: if request.auth != null
        && tenantOf(request.auth.uid) == tenantId
        && userRole() in ['admin','operation_manager','production_agent',
                          'graphic_designer','design_operator'];
      allow write: if request.auth != null
        && tenantOf(request.auth.uid) == tenantId
        && userRole() in ['admin','operation_manager','production_agent','design_operator']
        && request.resource.size < 50 * 1024 * 1024;
    }

    // ملفات الإنتاج — tenant + order scoped
    match /production/{tenantId}/{orderId}/{file=**} {
      allow read: if request.auth != null
        && tenantOf(request.auth.uid) == tenantId
        && userRole() in ['admin','operation_manager','production_agent'];
      allow write: if request.auth != null
        && tenantOf(request.auth.uid) == tenantId
        && userRole() in ['admin','operation_manager','production_agent']
        && request.resource.size < 50 * 1024 * 1024;
    }

    // ══════════════════════════════════════════════════════════
    // Client self-service media — بوابة العميل (كارت رقمي + معرض أعمال)
    // ══════════════════════════════════════════════════════════
    // الـ frontend (uploadClientFile) يبني الـ path: clients/{uid}/{kind}/{ts}_{name}
    // الكتابة: صاحب الحساب فقط (request.auth.uid == clientId).
    // القراءة: عامة لوسائط الكارت (logo/cover/works/gallery) لأن صفحة الأعمال
    //          عامة قابلة للمشاركة؛ باقي الأنواع للمالك فقط.
    match /clients/{clientId}/{kind}/{file=**} {
      allow read: if kind in ['logo','cover','works','gallery']
                  || (request.auth != null && request.auth.uid == clientId);
      allow write: if request.auth != null
        && request.auth.uid == clientId
        && request.resource.size < 60 * 1024 * 1024
        && ( request.resource.contentType.matches('image/.*')
             || request.resource.contentType.matches('video/.*')
             || request.resource.contentType == 'application/pdf' );
    }

    // ══════════════════════════════════════════════════════════
    // LEGACY paths — backward compat (deprecation pending migration)
    // ══════════════════════════════════════════════════════════
    // هذه الـ paths القديمة لا تحتوي tenantId. الصفحات الموجودة تستمر
    // ترفع إليها. مع migration الـ frontend خلال 3 شهور، الـ writes
    // الجديدة تنتقل إلى الـ paths المنفصلة أعلاه.
    //
    // التضييق المحدود الآمن:
    //   - الـ read محصور على staff (الـ public لا يقرأ receipts/designs)
    //   - الـ write يبقى كما كان لتفادي كسر uploads حالية

    // إيصالات طلبات الدفع — LEGACY
    match /receipts/{file=**} {
      allow read:  if request.auth != null && isStaff();
      allow write: if request.auth != null && isStaff()
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // ملفات التصميم — LEGACY
    match /designs/{file=**} {
      allow read:  if request.auth != null && isStaff();
      allow write: if request.auth != null && isStaff()
        && request.resource.size < 20 * 1024 * 1024;
    }
    match /design-refs/{file=**} {
      allow read:  if request.auth != null && isStaff();
      allow write: if request.auth != null && isStaff()
        && request.resource.size < 20 * 1024 * 1024;
    }
    // ملفات التصميم المهيكلة — LEGACY (paths بدون tenant)
    match /design-files/{file=**} {
      allow read:  if request.auth != null && isStaff();
      allow write: if request.auth != null && isStaff()
        && request.resource.size < 50 * 1024 * 1024;
    }
    // ملفات الطباعة النهائية — LEGACY
    match /print-finals/{file=**} {
      allow read:  if request.auth != null && isStaff();
      allow write: if request.auth != null && isStaff()
        && request.resource.size < 50 * 1024 * 1024;
    }
    // ملفات الإنتاج — LEGACY
    match /production/{file=**} {
      allow read:  if request.auth != null && isStaff();
      allow write: if request.auth != null && isStaff()
        && request.resource.size < 50 * 1024 * 1024;
    }
    // ملفات الجاليري العام — قراءة عامة (للزوار)، الكتابة للمصممين/الأدمن فقط
    match /gallery/{file=**} {
      allow read:  if true;
      allow write: if request.auth != null
        && userRole() in ['admin','operation_manager','customer_service',
                          'graphic_designer','design_operator']
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // صور المنتجات النهائية
    match /product-images/{file=**} {
      allow read:  if request.auth != null && isStaff();
      allow write: if request.auth != null
        && userRole() in ['admin','operation_manager','production_agent','graphic_designer']
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // ملفات الشات (نصوص + صوت + ملفات) — staff only
    match /chat/{file=**} {
      allow read:  if request.auth != null && isStaff();
      allow write: if request.auth != null && isStaff()
        && request.resource.size < 20 * 1024 * 1024;
    }
    // ستوريز الموظفين/الفريق — staff only
    match /stories/{file=**} {
      allow read:  if request.auth != null && isStaff();
      allow write: if request.auth != null && isStaff()
        && request.resource.size < 20 * 1024 * 1024;
    }
    // ملفات الموظفين المهيكلة (incidents/documents/contracts/avatar) — staff only
    // الـ frontend (uploadEmployeeFile) يبني الـ path: employees/{empId}/{kind}/{ts}_{name}
    // صور إثبات المخالفات (incidents) + مستندات الموظف. صور أو PDF فقط.
    match /employees/{empId}/{kind}/{file=**} {
      allow read:  if request.auth != null && isStaff();
      allow write: if request.auth != null && isStaff()
        && request.resource.size < 20 * 1024 * 1024
        && ( request.resource.contentType.matches('image/.*')
             || request.resource.contentType == 'application/pdf' );
    }
    // أي مسار آخر — مرفوض افتراضياً (default-deny)
    // لإضافة مسار جديد، أضفه أعلاه صراحةً.
  }
}
