rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // إيصالات طلبات الدفع — أي مستخدم مصادق عليه يستطيع الرفع/القراءة
    match /receipts/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // ملفات التصميم — أي مستخدم مصادق
    match /designs/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }
    match /design-refs/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }
    // أي ملف آخر — للأدمن فقط افتراضياً
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
