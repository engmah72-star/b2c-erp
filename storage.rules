rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // إيصالات طلبات الدفع — أي مستخدم مصادق عليه يستطيع الرفع/القراءة
    match /receipts/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // ملفات التصميم — أي مستخدم مصادق
    match /designs/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }
    match /design-refs/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }
    // ملفات الجاليري العام — قراءة عامة (للزوار)، الكتابة للمصادقين
    match /gallery/{file=**} {
      allow read:  if true;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // ملفات التصميم المهيكلة per-client/order/item/version
    match /design-files/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024;
    }
    // ملفات الطباعة النهائية
    match /print-finals/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024;
    }
    // صور المنتجات النهائية
    match /product-images/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // ملفات الإنتاج النهائية
    match /production/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024;
    }
    // ملفات الشات (نصوص + صوت + ملفات)
    match /chat/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }
    // ستوريز الموظفين/الفريق
    match /stories/{file=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024;
    }
    // أي مسار آخر — مرفوض افتراضياً (default-deny)
    // لإضافة مسار جديد، أضفه أعلاه صراحةً.
  }
}
